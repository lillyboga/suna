{
  "name": "kortix-api",
  "version": "1.0.0",
  "description": "Kortix API - Unified monolith combining router, billing, platform, cron, and daytona-proxy",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenvx run -f .env -- bun run --hot src/index.ts",
    "dev:dev-env": "dotenvx run -f .env.dev -- bun run --hot src/index.ts",
    "dev:prod-env": "dotenvx run -f .env.prod -- bun run --hot src/index.ts",
    "dev:envfile": "bun --env-file=.env.local run --hot src/index.ts",
    "start": "dotenvx run -- bun run src/index.ts",
    "migration:legacy-sandboxes": "dotenvx run -- bun run src/scripts/migrate-legacy-sandboxes.ts",
    "migration:legacy-fleet": "dotenvx run -- bun run src/scripts/migrate-legacy-fleet.ts",
    "e2e:flow": "bun run scripts/e2e-managed-flow.ts",
    "typecheck": "tsc --noEmit",
    "test": "dotenvx run -- bash -c 'for f in src/__tests__/billing/*.test.ts src/__tests__/e2e-*.test.ts src/__tests__/unit-*.test.ts; do bun test \"$f\" || exit 1; done'",
    "test:all": "bun run test"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.184.0",
    "@hono/zod-openapi": "^0.19.10",
    "@kortix/db": "workspace:*",
    "@kortix/llm-gateway": "workspace:*",
    "@kortix/manifest-schema": "workspace:*",
    "@kortix/shared": "workspace:*",
    "@kortix/starter": "workspace:*",
    "@logtail/node": "^0.5.8",
    "@scalar/hono-api-reference": "^0.10.20",
    "@sentry/bun": "^10.47.0",
    "@supabase/supabase-js": "^2.95.3",
    "agent-tunnel": "workspace:@kortix/agent-tunnel@*",
    "croner": "^9.0.0",
    "dockerode": "^4.0.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.4.0",
    "opencode-ai": "1.14.28",
    "postgres": "^3.4.8",
    "smol-toml": "^1.6.1",
    "stripe": "^14.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/dockerode": "^3.3.35",
    "bun-types": "^1.3.12",
    "typescript": "^5.4.0"
  }
}
